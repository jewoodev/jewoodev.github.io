---
layout: compress
swcache: true
---

[
  {% for post in site.posts %}
    {%- capture description -%}
      {% if post.excerpt %}
        {{ post.excerpt | strip_html | strip_newlines | truncate: 400 | jsonify }}
      {% else %}
        {{ post.content | strip_html | strip_newlines | truncate: 400 | jsonify }}
      {% endif %}
    {%- endcapture -%}
  {
    "title": {{ post.title | jsonify }},
    "url": {{ post.url | relative_url | jsonify }},
    "categories": {{ post.categories | join: ', ' | jsonify }},
    "tags": {{ post.tags | join: ', ' | jsonify }},
    "date": "{{ post.date }}",
    "content": {{ description }}
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
